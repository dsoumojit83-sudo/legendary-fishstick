# ========================
.DS_Store
.AppleDouble
.LSOverride

# ========================
# Logs
# ========================
*.log
npm-debug.log*

# ========================
# Editor / IDE
# ========================
.vscode/
.idea/
*.suo
*.user

# ========================
# One-time migration / patch scripts (DELETED)
# ========================
